# Scanner mode: "ws" for real WebSocket gateway "sim" for simulated demo
VITE_SCANNER_MODE=ws

# WebSocket URL for the scanner gateway
VITE_QR_WS_URL=ws://localhost:8788/ws

# Channel name (must match exe channel)
VITE_QR_CHANNEL=demo

# QR timeout in ms (how long before QR disappears after last update)
VITE_QR_TIMEOUT_MS=1500

# Show demo simulate/reset buttons (true/false)
VITE_SHOW_DEMO_BUTTONS=false
